{
  "name": "moa-management-system",
  "productName": "MOA Management System",
  "version": "1.0.0",
  "description": "MOA (Memorandum of Agreement) Management System - Desktop Application for managing and organizing MOA documents",
  "type": "module",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "cd frontend && npm install && npm run build && cd .. && mkdir -p dist && cp -r frontend/dist/* dist/",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "backend": "cd backend && npm install && node server-postgresql.js",
    "backend:cloud": "cd backend && npm install && npm run dev",
    "frontend": "cd frontend && npm install && npm run dev",
    "frontend:build": "cd frontend && npm install && npm run build",
    "dev:self-hosted": "concurrently \"npm run backend\" \"npm run frontend\"",
    "dev:cloud": "concurrently \"npm run backend:cloud\" \"npm run frontend\"",
    "build:self-hosted": "npm run frontend:build",
    "build:cloud": "cd backend && npm install && cd ../frontend && npm install && npm run build",
    "docker:build": "docker-compose build",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "moa",
    "memoranda",
    "agreement",
    "management",
    "document"
  ],
  "author": "no name",
  "license": "MIT",
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "concurrently": "^9.2.1",
    "electron": "40.0.0",
    "electron-builder": "^26.7.0",
    "vite": "^5.4.21",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "electron-squirrel-startup": "^1.0.1"
  },
  "build": {
    "productName": "MOA Management System",
    "appId": "com.moasystem.app",
    "asar": true,
    "asarUnpack": ["node_modules/better-sqlite3/**/*"],
    "files": [
      "dist/**/*",
      "src/**/*",
      "node_modules/better-sqlite3/**/*",
      "package.json",
      "logo.ico"
    ],
    "directories": {
      "buildResources": ".",
      "output": "dist-app"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MOA Management System",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "publish": null
  }
}
