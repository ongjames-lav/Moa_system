{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/assets/(.*)", "destination": "/dist/assets/$1" },
    { "source": "/favicon.ico", "destination": "/dist/favicon.ico" },
    { "source": "/((?!api/).*)", "destination": "/dist/index.html" }
  ]
}
