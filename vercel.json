{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "framework": "vite",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend/server.js",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/server.js" },
    { "source": "/((?!api/).*)", "destination": "frontend/index.html" }
  ]
}
